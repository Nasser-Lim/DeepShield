# ===== FastAPI Gateway =====
API_HOST=0.0.0.0
API_PORT=8080
RUNPOD_INFERENCE_URL=https://[POD_ID]-8000.proxy.runpod.net
RUNPOD_INFERENCE_TIMEOUT=120

# Verdict thresholds on the single DIRE synthetic probability
THRESHOLD_SAFE=0.30
THRESHOLD_RISK=0.70

# ===== Next.js Web =====
NEXT_PUBLIC_API_URL=http://localhost:8080

# ===== RunPod Inference (DIRE) =====
INFER_HOST=0.0.0.0
INFER_PORT=8000
DEVICE=cuda
UPLOAD_DIR=/workspace/dire_v1/uploads

# DIRE-specific paths on the Pod volume
DIRE_REPO_PATH=/workspace/dire_v1/repo
DIRE_ADM_WEIGHTS=/workspace/dire_v1/weights/256x256_diffusion_uncond.pt
DIRE_CLASSIFIER_WEIGHTS=/workspace/dire_v1/weights/classifier/lsun_adm.pth
DIRE_TIMESTEP_RESPACING=ddim20
DIRE_IMAGE_SIZE=256
